// ==========================================
// ЯДРО БАЗЫ ДАННЫХ ROYAL BANNERS (ERP & CRM)
// ==========================================

datasource db {
  provider = "postgresql" // Оставляем твой PostgreSQL
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. ПОЛЬЗОВАТЕЛИ (Админ, Менеджеры, постоянные B2B клиенты)
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Хэш пароля
  role      Role     @default(CLIENT)
  name      String?
  phone     String?
  orders    Order[]  // Связь: один клиент может иметь много заказов
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. ПОРТФОЛИО (Кейсы из Instagram, витрина)
// ==========================================
model Portfolio {
  id          String   @id @default(uuid())
  title       String   // "Вывеска для GLOBAL DENT"
  category    ServiceCategory // "BANNERS", "METAL_FRAMES" и т.д.
  
  // 🔥 SENIOR UPDATE: Теперь это МАССИВЫ строк, чтобы хранить несколько фото!
  imageUrls   String[] 
  publicIds   String[] 
  
  description String?
  isVisible   Boolean  @default(true) // Можно временно скрыть
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 3. ЗАКАЗЫ (Падают с калькулятора в CRM)
// ==========================================
model Order {
  id          String      @id @default(uuid())
  
  client      User?       @relation(fields: [clientId], references: [id])
  clientId    String?     // Может быть null, если заказ от гостя без регистрации

  customerName String     // Имя заказчика (особенно если без регистрации)
  phone       String      // Обязательно для связи
  
  // Детали с калькулятора
  serviceType ServiceCategory // Тип услуги
  width       Float?      // Ширина в метрах (не для всех услуг нужно)
  height      Float?      // Высота в метрах
  material    String?     // "Оракал", "Баннер 440г"
  hasEyelets  Boolean     @default(false) // Люверсы
  needsMount  Boolean     @default(false) // Нужен монтаж
  
  description String?     // Текстовое поле для сохранения сложных деталей
  totalPrice  Int         // Итоговая цена в тенге
  status      OrderStatus @default(NEW)
  
  expenses    Expense[]   // Расходы, привязанные к этому заказу (себестоимость)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ==========================================
// 4. НАСТРОЙКИ КАЛЬКУЛЯТОРА И СИСТЕМЫ (JSON)
// ==========================================
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // Например: "calculator_config"
  value     Json     // Сюда будет сохраняться вся сложная архитектура (формулы, инпуты)
  updatedAt DateTime @updatedAt
}

// ==========================================
// 5. ПРАЙС-ЛИСТ (БАЗОВЫЕ ЦЕНЫ ДЛЯ КАЛЬКУЛЯТОРА)
// ==========================================
model Price {
  id        String   @id @default(uuid())
  service   String   @unique // Например: "Печать баннера 340гр"
  unit      String   // "1 кв.м"
  price     Int      // Стоимость в тенге
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 6. ФИНАНСЫ (ОБЩИЕ РАСХОДЫ И РАСХОДЫ ПО ЗАКАЗАМ)
// ==========================================
model Expense {
  id        String   @id @default(uuid())
  category  String   // "Материалы", "Аренда цеха", "Зарплата", "Таргет"
  amount    Int      // Сумма расхода
  comment   String?
  date      DateTime @default(now())
  
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ==========================================
// ПЕРЕЧИСЛЕНИЯ ДЛЯ СТРОГОЙ ТИПИЗАЦИИ
// ==========================================
enum Role {
  ADMIN
  MANAGER
  CLIENT
}

enum OrderStatus {
  NEW         // Только упала заявка
  PENDING     // В ожидании / на согласовании (замер)
  IN_PROGRESS // В производстве
  READY       // Ждет отгрузки/монтажа
  COMPLETED   // Закрыт и оплачен
  CANCELED    // Отменен
}

// Категории услуг (взяты из реального прайса/инсты)
enum ServiceCategory {
  BANNERS         // Баннеры, наружная реклама
  LIGHTBOXES      // Лайтбоксы
  SIGNBOARDS      // Вывески
  INTERIOR        // Оформление интерьера и экстерьера
  FIGURES_3D      // Объемные фигуры
  METAL_FRAMES    // Металлокаркасы
  POS_MATERIALS   // ПОС материалы
  DESIGN_PRINT    // Дизайн и печать
}